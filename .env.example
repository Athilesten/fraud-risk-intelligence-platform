# -------------------------------
# Database
# -------------------------------
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=fraud_local_password_123
POSTGRES_DB=fraud_db

# Used by the local API when running outside Docker.
DATABASE_URL=postgresql://fraud_user:fraud_local_password_123@localhost:5433/fraud_db


# -------------------------------
# API Security
# -------------------------------
# Local demo key used by React and Streamlit during development.
FRAUD_API_KEY=dev_fraud_api_key_123
JWT_SECRET_KEY=local_demo_jwt_secret_change_me
JWT_EXPIRES_MINUTES=120
DEMO_ADMIN_EMAIL=admin@fraud.local
DEMO_ADMIN_PASSWORD=admin123
DEMO_ADMIN_ROLE=admin
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_AUDIENCE=

# Browser origins allowed to call FastAPI.
FRAUD_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3001,http://127.0.0.1:3001,http://localhost:8501


# -------------------------------
# App URLs
# -------------------------------
# Docker-internal URL used by Streamlit container.
API_BASE_URL=http://fraud-api:8000

# Browser URL used by the React frontend.
VITE_API_BASE_URL=http://localhost:8000
VITE_API_KEY=dev_fraud_api_key_123
VITE_ENABLE_AUTH=false

PUBLIC_FASTAPI_DOCS_URL=http://localhost:8000/docs
PUBLIC_FASTAPI_HEALTH_URL=http://localhost:8000/health
PUBLIC_PROMETHEUS_URL=http://localhost:9090
PUBLIC_GRAFANA_URL=http://localhost:3000
PUBLIC_STREAMLIT_URL=http://localhost:8501


# -------------------------------
# Monitoring
# -------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana_local_password_123


# -------------------------------
# Streaming
# -------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_BOOTSTRAP_SERVER=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_RAW_TOPIC=transactions.raw
KAFKA_SCORED_TOPIC=transactions.scored
KAFKA_ERRORS_TOPIC=transactions.errors
KAFKA_ERROR_TOPIC=transactions.errors
KAFKA_TOPIC=transactions.raw
DATA_LAKE_PATH=data/delta
FRAUD_API_URL=http://127.0.0.1:8000/predict
MAX_API_RETRIES=3
