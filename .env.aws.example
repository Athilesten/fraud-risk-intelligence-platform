AWS_REGION=ap-south-1
APP_NAME=fraud-risk-intelligence-platform
ENVIRONMENT=dev

# React frontend
VITE_API_BASE_URL=https://your-api-domain.com
VITE_API_KEY=replace_with_secret_manager_value

# FastAPI
FRAUD_API_KEY=replace_with_secret_manager_value
JWT_SECRET_KEY=replace_with_secret_manager_value

# Future RDS PostgreSQL
DATABASE_URL=postgresql://username:password@rds-endpoint:5432/fraud_db

# Future MSK Kafka
KAFKA_BOOTSTRAP_SERVERS=your-msk-bootstrap-server:9092
KAFKA_RAW_TOPIC=transactions.raw
KAFKA_SCORED_TOPIC=transactions.scored
KAFKA_ERROR_TOPIC=transactions.errors

# Future S3 data lake
DATA_LAKE_PATH=s3://your-fraud-risk-lake-dev